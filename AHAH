			local prefix = GetCurrentPrefix()
			if prefix ~= "" and prefix ~= lastAutoPrefix then
				local chosen = PickAutoPlayWord(prefix)
				if chosen and chosen ~= "" and chosen ~= lastAutoChosen then
					lastAutoPrefix = prefix
					lastAutoChosen = chosen
					TypeWordAutoPlay(chosen)
				end
			end
		else
			lastAutoPrefix = ""
		end
	end
end)

