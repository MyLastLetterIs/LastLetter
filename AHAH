local function NormalizeCustomTag(rawTag)
    rawTag = tostring(rawTag or "all"):lower()
    if rawTag == "trap" then
        return "trap"
    end
    if rawTag == "solve" then
        return "solve"
    end
    return "all"
end

local function NormalizeCustomInfo(tag, difficulty)
    tag = NormalizeCustomTag(tag)
    difficulty = tonumber(difficulty) or 0

    if tag == "trap" then
        if difficulty < 1 then
            difficulty = 1
        end
        if difficulty > 9 then
            difficulty = 9
        end
    else
        difficulty = 0
    end

    return tag, difficulty
end

local function ParseCustomEntry(entry)
    local text = tostring(entry or ""):lower()

    local tag = "all"
    local difficulty = tonumber(text:match("(%d+)%s*%*")) or 0

    if text:find("|") then
        local parts = {}
        for part in text:gmatch("[^|]+") do
            table.insert(parts, part)
        end
        local word = (parts[1] or ""):gsub("%s+", "")
        tag = NormalizeCustomTag(parts[2] or "all")
        difficulty = tonumber(parts[3]) or difficulty
        tag, difficulty = NormalizeCustomInfo(tag, difficulty)
        if word == "" then
            return nil, nil, 0
        end
        return word, tag, difficulty
    end

    if text:find("%+solve%+") then
        tag = "solve"
    elseif text:find("%+trap%+") then
        tag = "trap"
    end

    text = text:gsub("%+solve%+", "")
    text = text:gsub("%+trap%+", "")
    text = text:gsub("%d+%s*%*", "")
    text = text:gsub("%s+", "")

    if text == "" then
        return nil, nil, 0
    end

    tag, difficulty = NormalizeCustomInfo(tag, difficulty)
    return text, tag, difficulty
end

local function AddWordToBuckets(word, isCustom, customTag, customDifficulty)
    word = tostring(word or ""):lower():gsub("%s+", "")
    if not word:match("^[a-z]+$") then
        return false
    end
    if #word < 3 then
        return false
    end

    local inserted = false

    if not WordSet[word] then
        WordSet[word] = true
        table.insert(Words, word)
        inserted = true

        local p1 = word:sub(1, 1)
        local p2 = word:sub(1, 2)
        local p3 = word:sub(1, 3)
        local s1 = word:sub(-1)
        local s2 = word:sub(-2)
        local s3 = word:sub(-3)

        if #p1 == 1 then
            AddToBucket(PrefixBuckets1, p1, word)
        end
        if #p2 == 2 then
            AddToBucket(PrefixBuckets2, p2, word)
        end
        if #p3 == 3 then
            AddToBucket(PrefixBuckets3, p3, word)
        end
        if #s1 == 1 then
            AddToBucket(SuffixBuckets1, s1, word)
        end
        if #s2 == 2 then
            AddToBucket(SuffixBuckets2, s2, word)
        end
        if #s3 == 3 then
            AddToBucket(SuffixBuckets3, s3, word)
        end
    end

    if isCustom then
        local tag, diff = NormalizeCustomInfo(customTag, customDifficulty)
        CustomWordSet[word] = true
        CustomWordTags[word] = tag
        CustomWordDiffs[word] = diff
    end

    return inserted
end

local function FetchUrl(url)
    local ok1, body1 = pcall(function()
        return game:HttpGet(url, true)
    end)
    if ok1 and type(body1) == "string" and #body1 > 0 then
        return body1
    end

    local ok2, resp = pcall(function()
        return HttpService:RequestAsync({
            Url = url,
            Method = "GET"
        })
    end)

    if ok2 and resp and resp.Success and type(resp.Body) == "string" and #resp.Body > 0 then
        return resp.Body
    end

    return nil
end

local function LoadDictionaries()
    local loadedUnique = 0

    if isfile(WORDS_FILE) then
        local content = readfile(WORDS_FILE)
        for word in content:gmatch("%S+") do
            if AddWordToBuckets(word, false) then
                loadedUnique = loadedUnique + 1
            end
        end
        print("Loaded " .. loadedUnique .. " unique words from cache")
        print("TOTAL UNIQUE WORDS: " .. #Words)
        return
    end

    local allText = ""
    for _, url in ipairs(dictionaries) do
        local body = FetchUrl(url)
        if body and #body > 1000 then
            allText = allText .. "\n" .. body
        else
            warn("Skipped or failed: " .. url)
        end
        task.wait(0.8)
    end

    if allText ~= "" then
        writefile(WORDS_FILE, allText)
        for word in allText:gmatch("%S+") do
            if AddWordToBuckets(word, false) then
                loadedUnique = loadedUnique + 1
            end
        end
        print("Combined unique words: " .. loadedUnique)
    end

    print("TOTAL UNIQUE WORDS: " .. #Words)
end

local function LoadCustomWords()
    if not isfile(CUSTOM_WORDS_FILE) then
        return
    end

    local content = readfile(CUSTOM_WORDS_FILE)
    for line in content:gmatch("[^\r\n]+") do
        local word, tag, diff = line:match("^([^|]+)|([^|]+)|([^|]+)$")
        if not word then
            word, tag = line:match("^([^|]+)|([^|]+)$")
            diff = 0
        end
        if not word then
            word, tag, diff = ParseCustomEntry(line)
        end

        if word and word:match("^[a-z]+$") and #word >= 3 then
            AddWordToBuckets(word, true, tag or "all", diff or 0)
        end
    end

    ClearCaches()
    print("Loaded custom words: " .. tostring(CountCustomWords()))
end

local function SaveCustomWords()
    local list = {}
    for word in pairs(CustomWordSet) do
        local tag = NormalizeCustomTag(CustomWordTags[word] or "all")
        local diff = tonumber(CustomWordDiffs[word] or 0) or 0
        table.insert(list, word .. "|" .. tag .. "|" .. tostring(diff))
    end
    table.sort(list)
    writefile(CUSTOM_WORDS_FILE, table.concat(list, "\n"))
end

