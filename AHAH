local function RenderSearch(query)
local data = SearchWords(query, searchMode)
local totalPages = GetPageCount(data.normal, data.custom, pageSize)
if currentPage > totalPages then
currentPage = totalPages
end
if currentPage < 1 then
currentPage = 1
end

local pageNormal = SlicePage(data.normal, currentPage, pageSize)  
local pageCustom = SlicePage(data.custom, currentPage, pageSize)  

RemoveResultChildren()  
MakeHeader("Search (" .. searchMode:upper() .. "): " .. query .. " | Page " .. currentPage .. "/" .. totalPages)  

local customEntries = {}  
for _, word in ipairs(pageCustom) do  
	table.insert(customEntries, { display = word, value = word })  
end  

local normalEntries = {}  
for _, word in ipairs(pageNormal) do  
	table.insert(normalEntries, { display = word, value = word })  
end  

if #customEntries > 0 then  
	BuildSectionItems("Custom Words:", customEntries, "")  
end  

BuildSectionItems("Results:", normalEntries, "No matches")

end

local function RenderPrefix(prefix)
local totalPages = 1
local suggesterData = nil
local trapData = nil

if suggesterEnabled then  
	suggesterData = GetSuggestions(prefix)  
	totalPages = math.max(totalPages, GetPageCount(suggesterData.normal, suggesterData.custom, pageSize))  
end  

if trapModeEnabled then  
	trapData = FindTraps(prefix)  
	totalPages = math.max(totalPages, GetPageCount(trapData.normal, trapData.custom, pageSize))  
end  

if currentPage > totalPages then  
	currentPage = totalPages  
end  
if currentPage < 1 then  
	currentPage = 1  
end  

RemoveResultChildren()  
MakeHeader("Prefix: " .. prefix:upper() .. " | Page " .. currentPage .. "/" .. totalPages)  

if suggesterEnabled and suggesterData then  
	local pageNormal = SlicePage(suggesterData.normal, currentPage, pageSize)  
	local pageCustom = SlicePage(suggesterData.custom, currentPage, pageSize)  

	local customEntries = {}  
	for _, word in ipairs(pageCustom) do  
		table.insert(customEntries, { display = word, value = word })  
	end  

	local normalEntries = {}  
	for _, word in ipairs(pageNormal) do  
		table.insert(normalEntries, { display = word, value = word })  
	end  

	if #customEntries > 0 then  
		BuildSectionItems("Custom Words:", customEntries, "")  
	end  

	BuildSectionItems("Suggestions:", normalEntries, "No matches")  
end  

if trapModeEnabled and trapData then  
	local pageNormal = SlicePage(trapData.normal, currentPage, pageSize)  
	local pageCustom = SlicePage(trapData.custom, currentPage, pageSize)  

	local customEntries = {}  
	for _, text in ipairs(pageCustom) do  
		local word = text:match("^(.-)%s*%-%>%s*trap:")  
		table.insert(customEntries, { display = text, value = word or text })  
	end  

	local normalEntries = {}  
	for _, text in ipairs(pageNormal) do  
		local word = text:match("^(.-)%s*%-%>%s*trap:")  
		table.insert(normalEntries, { display = text, value = word or text })  
	end  

	if #customEntries > 0 then  
		BuildSectionItems("Custom Words:", customEntries, "")  
	end  

	BuildSectionItems("Traps:", normalEntries, "No traps")  
end  

if not suggesterEnabled and not trapModeEnabled then  
	MakeEmpty("Turn Suggester or Trap Mode ON")  
end

end

