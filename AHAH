local lastPrefix = ""
local lastSearch = ""
local lastSearchMode = ""
local lastPriority = ""
local lastCustomPriority = ""
local lastSuggesterState = false
local lastTrapState = false
local lastRenderedText = ""
local lastUpdate = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastUpdate < 0.12 then
        return
    end
    lastUpdate = now

    local query = searchBox.Text:gsub("^%s+", ""):gsub("%s+$", ""):lower()
    local needsSearch = query ~= ""

    if needsSearch then
        if query == lastSearch and searchMode == lastSearchMode and lengthPriority == lastPriority and customWordPriority == lastCustomPriority and not uiDirty then
            return
        end

        local text = RenderSearch(query)
        if text ~= lastRenderedText then
            suggestionLabel.Text = text
            lastRenderedText = text
        end

        lastSearch = query
        lastSearchMode = searchMode
        lastPriority = lengthPriority
        lastCustomPriority = customWordPriority
        uiDirty = false
        return
    end

    local prefix = GetLivePrefix()
    if prefix == "" then
        local text = "Turn Suggester or Trap Mode ON"
        if suggestionLabel.Text ~= text then
            suggestionLabel.Text = text
            lastRenderedText = text
        end
        uiDirty = false
        lastPrefix = ""
        return
    end

    if prefix == lastPrefix and not uiDirty and searchMode == lastSearchMode and lengthPriority == lastPriority and customWordPriority == lastCustomPriority and suggesterEnabled == lastSuggesterState and trapModeEnabled == lastTrapState then
        return
    end

    local text = RenderPrefix(prefix)
    if text ~= lastRenderedText then
        suggestionLabel.Text = text
        lastRenderedText = text
    end

    lastPrefix = prefix
    lastSearch = ""
    lastSearchMode = searchMode
    lastPriority = lengthPriority
    lastCustomPriority = customWordPriority
    lastSuggesterState = suggesterEnabled
    lastTrapState = trapModeEnabled
    uiDirty = false
end)

