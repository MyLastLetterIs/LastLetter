local function AddToBucket(bucket, key, word)
	bucket[key] = bucket[key] or {}
	bucket[key][#bucket[key] + 1] = word
end

local function ClearCaches()
	SuggestionCache = {}
	TrapCache = {}
	SearchCache = {}
	SuffixCountCache = {}
end

local function IsBlacklisted(word)
	word = tostring(word or ""):lower():gsub("%s+", "")
	return PersistentBlacklist[word] == true or RuntimeBlacklist[word] == true
end

local function AddWordToBuckets(word, isCustom)
	word = tostring(word or ""):lower():gsub("%s+", "")
	if not word:match("^[a-z]+$") or #word < 3 then
		return false
	end

	if not WordSet[word] then
		WordSet[word] = true
		Words[#Words + 1] = word
		AddToBucket(PrefixBuckets1, word:sub(1, 1), word)
		AddToBucket(PrefixBuckets2, word:sub(1, 2), word)
		AddToBucket(PrefixBuckets3, word:sub(1, 3), word)
		AddToBucket(SuffixBuckets1, word:sub(-1), word)
		AddToBucket(SuffixBuckets2, word:sub(-2), word)
		AddToBucket(SuffixBuckets3, word:sub(-3), word)
	end

	if isCustom then
		CustomWordSet[word] = true
	end

	return true
end

local function FetchUrl(url)
	local ok, body = pcall(function()
		return game:HttpGet(url, true)
	end)
	if ok and type(body) == "string" and #body > 0 then
		return body
	end
	local ok2, resp = pcall(function()
		return HttpService:RequestAsync({ Url = url, Method = "GET" })
	end)
	if ok2 and resp and resp.Success and type(resp.Body) == "string" and #resp.Body > 0 then
		return resp.Body
	end
	return nil
end

local function LoadDictionaries()
	if isfile(WORDS_FILE) then
		for w in readfile(WORDS_FILE):gmatch("%S+") do
			AddWordToBuckets(w, false)
		end
		return
	end

	local all = ""
	for _, url in ipairs(dictionaries) do
		local body = FetchUrl(url)
		if body and #body > 1000 then
			all ..= "\n" .. body
		end
		task.wait(0.5)
	end

	if all ~= "" then
		writefile(WORDS_FILE, all)
		for w in all:gmatch("%S+") do
			AddWordToBuckets(w, false)
		end
	end
end

local function LoadCustomWords()
	if not isfile(CUSTOM_WORDS_FILE) then
		return
	end
	for w in readfile(CUSTOM_WORDS_FILE):gmatch("%S+") do
		AddWordToBuckets(w, true)
	end
	ClearCaches()
end

