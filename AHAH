addCustomBtn.MouseButton1Click:Connect(function()
    local addedAny = false

    for word in customBox.Text:gmatch("([^,]+)") do
        word = word:lower():gsub("%s+", "")
        if #word >= 3 and not CustomWordSet[word] then
            CustomWordSet[word] = true
            AddWordToBuckets(word, true)
            addedAny = true
        end
    end

    customBox.Text = ""
    ClearCaches()

    if addedAny then
        pcall(SaveCustomWords)
    end

    MarkDirty()
    print("Custom words updated: " .. tostring(CountCustomWords()))
end)

local function UpdateModeButton()
    if searchMode == "word" then
        modeBtn.Text = "Word"
        modeBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
    elseif searchMode == "suffix" then
        modeBtn.Text = "Suffix"
        modeBtn.BackgroundColor3 = Color3.fromRGB(220, 140, 0)
    else
        modeBtn.Text = "Prefix"
        modeBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 220)
    end
end

modeBtn.MouseButton1Click:Connect(function()
    if searchMode == "word" then
        searchMode = "suffix"
    elseif searchMode == "suffix" then
        searchMode = "prefix"
    else
        searchMode = "word"
    end
    UpdateModeButton()
    MarkDirty()
end)

UpdateModeButton()

