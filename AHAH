local function VkToKeyCode(vk)
	if vk == 0x10 then
		return Enum.KeyCode.LeftShift
	end
	if vk == 0x0D then
		return Enum.KeyCode.Return
	end
	local ch = string.char(vk)
	return Enum.KeyCode[ch]
end

local function PressVk(vk)
	local ok = false
	if type(keypress) == "function" then
		ok = pcall(function()
			keypress(vk)
		end)
	end
	if not ok then
		local keyCode = VkToKeyCode(vk)
		if keyCode then
			pcall(function()
				game:GetService("VirtualInputManager"):SendKeyEvent(true, keyCode, false, game)
			end)
		end
	end
end

local function ReleaseVk(vk)
	local ok = false
	if type(keyrelease) == "function" then
		ok = pcall(function()
			keyrelease(vk)
		end)
	end
	if not ok then
		local keyCode = VkToKeyCode(vk)
		if keyCode then
			pcall(function()
				game:GetService("VirtualInputManager"):SendKeyEvent(false, keyCode, false, game)
			end)
		end
	end
end

local function FireKeyObject(obj)
	for _, signal in ipairs({"MouseButton1Click","Activated","InputBegan"}) do
		if obj[signal] then
			for _, v in ipairs(getconnections(obj[signal])) do
				pcall(function()
					v:Fire()
				end)
			end
		end
	end
end

local function FindKeyObject(char)
	local player = game:GetService("Players").LocalPlayer
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return nil end

	local overbar = gui:FindFirstChild("Overbar")
	if not overbar then return nil end

	local frame = overbar:FindFirstChild("Frame")
	if not frame then return nil end

	local keyboard = frame:FindFirstChild("Keyboard")
	if not keyboard then return nil end

	char = char:upper()

	for _, rowName in ipairs({"1","2","3"}) do
		local row = keyboard:FindFirstChild(rowName)
		if row then
			for _, keyObj in ipairs(row:GetChildren()) do
				if keyObj.Name:upper() == char then
					return keyObj
				end
			end
		end
	end

	return nil
end

local function TypeWordHumanized(word)
	task.spawn(function()
		local ok, err = pcall(function()
			local fullWord = tostring(word or ""):lower()
			if #fullWord == 0 then return end

			local prefix = tostring(GetCurrentPrefix() or ""):lower()

			local startIndex = 1
			if prefix ~= "" then
				local maxLen = math.min(#prefix, #fullWord)

				for i = 1, maxLen do
					if prefix:sub(i,i) ~= fullWord:sub(i,i) then
						break
					end
					startIndex = i + 1
				end
			end

			local remaining = fullWord:sub(startIndex)
			if #remaining == 0 then return end

			for i = 1, #remaining do
				local char = remaining:sub(i, i)

				if char:match("%a") then
					local keyObj = FindKeyObject(char)
					if keyObj then
						FireKeyObject(keyObj)
					end
				end

				task.wait(math.random() * (maxDelay - minDelay) + minDelay)
			end

			task.wait(math.random() * (maxDelay - minDelay) + minDelay)

			PressVk(13)
			task.wait(0.02)
			ReleaseVk(13)

			pcall(function()
				game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Return, false, game)
				task.wait(0.02)
				game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.Return, false, game)
			end)
		end)

		if not ok then
			warn(err)
		end
	end)
end

