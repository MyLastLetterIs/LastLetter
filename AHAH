    "amh","anz","iga","keh","kup","rua"
}) do
    ManualTrap3[v] = true
end

local function AddToBucket(bucket, key, word)
    bucket[key] = bucket[key] or {}
    table.insert(bucket[key], word)
end

local function ClearCaches()
    SuggestionCache = {}
    TrapCache = {}
    SuffixCountCache = {}
end

local function CountCustomWords()
    local c = 0
    for _ in pairs(CustomWordSet) do
        c = c + 1
    end
    return c
end

local function AddWordToBuckets(word, isCustom)
    word = tostring(word or ""):lower():gsub("%s+", "")
    if not word:match("^[a-z]+$") then
        return
    end
    if #word < 3 then
        return
    end

    if not WordSet[word] then
        WordSet[word] = true
        table.insert(Words, word)

        local first = word:sub(1, 1)
        if first ~= "" then
            AddToBucket(PrefixBuckets1, first, word)
        end

        local second = word:sub(1, 2)
        if #second == 2 then
            AddToBucket(PrefixBuckets2, second, word)
        end
    end

    if isCustom then
        CustomWordSet[word] = true
    end
end

local function FetchUrl(url)
    local ok, result = pcall(function()
        return game:HttpGet(url, true)
    end)
    if ok and type(result) == "string" and #result > 0 then
        return result
    end

    local ok2, resp = pcall(function()
        return HttpService:RequestAsync({
            Url = url,
            Method = "GET"
        })
    end)

    if ok2 and resp and resp.Success and type(resp.Body) == "string" and #resp.Body > 0 then
        return resp.Body
    end

    return nil
end

local function LoadDictionaries()
    if isfile(WORDS_FILE) then
        local content = readfile(WORDS_FILE)
        for word in content:gmatch("%S+") do
            AddWordToBuckets(word, false)
        end
        print("Loaded " .. #Words .. " words from cache")
        return
    end

    local allText = ""
    for _, url in ipairs(dictionaries) do
        local body = FetchUrl(url)
        if body and #body > 1000 then
            allText = allText .. "\n" .. body
            print("Loaded: " .. url .. " | Size: " .. tostring(#body))
        else
            warn("Skipped or failed: " .. url)
        end
        task.wait(0.8)
    end

    if allText ~= "" then
        writefile(WORDS_FILE, allText)
        for word in allText:gmatch("%S+") do
            AddWordToBuckets(word, false)
        end
        print("Combined dictionary: " .. #Words .. " words")
    end

    print("TOTAL WORDS: " .. #Words)
end

local function LoadCustomWords()
    if not isfile(CUSTOM_WORDS_FILE) then
        return
    end

    local content = readfile(CUSTOM_WORDS_FILE)
    for word in content:gmatch("%S+") do
        AddWordToBuckets(word, true)
    end

    ClearCaches()
    print("Loaded custom words: " .. tostring(CountCustomWords()))
end

local function SaveCustomWords()
    local list = {}
    for word in pairs(CustomWordSet) do
        table.insert(list, word)
    end
    table.sort(list)
    writefile(CUSTOM_WORDS_FILE, table.concat(list, "\n"))
end

LoadDictionaries()
LoadCustomWords()

do
    local saved = false

    local function SaveOnce()
        if saved then
            return
        end
        saved = true
        pcall(SaveCustomWords)
    end

    player.AncestryChanged:Connect(function(_, parent)
        if parent == nil then
            SaveOnce()
        end
    end)

    pcall(function()
        game:BindToClose(function()
            SaveOnce()
        end)
    end)
end

