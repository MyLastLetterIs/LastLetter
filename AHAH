local function GetPageCount(normalList, customList, size)
	return math.max(math.max(1, math.ceil(#normalList / size)), math.max(1, math.ceil(#customList / size)))
end

local function SlicePage(items, page, size)
	local startIndex = ((page - 1) * size) + 1
	local endIndex = math.min(#items, startIndex + size - 1)
	local result = {}
	if startIndex > #items then
		return result
	end
	for i = startIndex, endIndex do
		result[#result + 1] = items[i]
	end
	return result
end

local function SearchWordMatches(word, query, mode, context)
	word = tostring(word or ""):lower()
	query = tostring(query or ""):lower()
	context = tostring(context or ""):lower()
	if query == "" then
		return false
	end

	if mode == "prefix" then
		if context ~= "" and word:sub(1, #context) ~= context then
			return false
		end
		return word:sub(1, #query) == query
	elseif mode == "suffix" then
		if context ~= "" and word:sub(1, #context) ~= context then
			return false
		end
		return word:sub(-#query) == query
	else
		if context ~= "" then
			return word:find(context, 1, true) ~= nil and word:find(query, 1, true) ~= nil
		end
		return word:find(query, 1, true) ~= nil
	end
end

local function GetSuggestions(prefix)
	local key = prefix .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
	if SuggestionCache[key] then
		return SuggestionCache[key]
	end

	local normal, custom = {}, {}
	for _, word in ipairs(GetPrefixCandidates(prefix)) do
		if not IsBlacklisted(word) and word:sub(1, #prefix) == prefix and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then
			if CustomWordSet[word] then
				custom[#custom + 1] = word
			else
				normal[#normal + 1] = word
			end
		end
	end

	ApplyPriority(normal)
	ApplyPriority(custom)
	SuggestionCache[key] = { normal = normal, custom = custom }
	return SuggestionCache[key]
end

local function GetCustomFallback(prefix)
	local out = {}
	for word in pairs(CustomWordSet) do
		if not IsBlacklisted(word) and word:sub(1, #prefix) == prefix and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then
			out[#out + 1] = word
		end
	end
	ApplyPriority(out)
	return out
end

local function GetSuffixCount(suffix)
	if SuffixCountCache[suffix] ~= nil then
		return SuffixCountCache[suffix]
	end

	local count = 0
	for _, word in ipairs(GetPrefixCandidates(suffix)) do
		if not IsBlacklisted(word) and word:sub(1, #suffix) == suffix then
			count += 1
		end
	end

	SuffixCountCache[suffix] = count
	return count
end

local function FindTraps(prefix)
	if TrapCache[prefix] then
		return TrapCache[prefix]
	end

	local normal, custom, checkedSuffix = {}, {}, {}
	for _, word in ipairs(GetPrefixCandidates(prefix)) do
		if not IsBlacklisted(word) and word:sub(1, #prefix) == prefix then
			local suffix2, suffix3 = word:sub(-2), word:sub(-3)
			local function handleSuffix(suffix, isManual)
				if #suffix >= 2 and not checkedSuffix[suffix] then
					checkedSuffix[suffix] = true
					local isTrap = isManual or (GetSuffixCount(suffix) > 0 and GetSuffixCount(suffix) <= 6)
					if isTrap then
						local text = word .. " -> trap: " .. suffix:upper()
						if CustomWordSet[word] then
							custom[#custom + 1] = text
						else
							normal[#normal + 1] = text
						end
					end
				end
			end
			handleSuffix(suffix3, ManualTrap3[suffix3] == true)
			handleSuffix(suffix2, ManualTrap2[suffix2] == true)
		end
	end

	ApplyPriority(normal)
	ApplyPriority(custom)
	TrapCache[prefix] = { normal = normal, custom = custom }
	return TrapCache[prefix]
end

local function SearchWords(query, mode)
	local context = suggesterEnabled and GetCurrentPrefix() or ""
	local key = mode .. "|" .. query .. "|" .. context .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
	if SearchCache[key] then
		return SearchCache[key]
	end

	local normal, custom = {}, {}
	if mode == "word" then
		for _, word in ipairs(Words) do
			if not IsBlacklisted(word) and SearchWordMatches(word, query, mode, context) and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then
				if CustomWordSet[word] then
					custom[#custom + 1] = word
				else
					normal[#normal + 1] = word
				end
			end
		end
	elseif mode == "prefix" then
		for _, word in ipairs(GetPrefixCandidates(query)) do
			if not IsBlacklisted(word) and SearchWordMatches(word, query, mode, context) and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then
				if CustomWordSet[word] then
					custom[#custom + 1] = word
				else
					normal[#normal + 1] = word
				end
			end
		end
	elseif mode == "suffix" then
		for _, word in ipairs(GetSuffixCandidates(query)) do
			if not IsBlacklisted(word) and SearchWordMatches(word, query, mode, context) and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then
				if CustomWordSet[word] then
					custom[#custom + 1] = word
				else
					normal[#normal + 1] = word
				end
			end
		end
	end

	ApplyPriority(normal)
	ApplyPriority(custom)
	SearchCache[key] = { normal = normal, custom = custom }
	return SearchCache[key]
end

local function GetActivePageCount()
	local query = searchBox.Text:gsub("^%s+", ""):gsub("%s+$", ""):lower()
	if query ~= "" then
		local data = SearchWords(query, searchMode)
		return GetPageCount(data.normal, data.custom, pageSize)
	end
	local prefix = GetCurrentPrefix()
	if prefix == "" then
		return 1
	end
	local totalPages = 1
	if suggesterEnabled then
		local data = GetSuggestions(prefix)
		totalPages = math.max(totalPages, GetPageCount(data.normal, data.custom, pageSize))
	end
	if trapModeEnabled then
		local data = FindTraps(prefix)
		totalPages = math.max(totalPages, GetPageCount(data.normal, data.custom, pageSize))
	end
	return totalPages
end

