local function GetCurrentPrefix()
    local inGame = playerGui:FindFirstChild("InGame")
    if not inGame then
        return ""
    end

    local frame = inGame:FindFirstChild("Frame")
    if not frame then
        return ""
    end

    local container = frame:FindFirstChild("CurrentWord")
    if not container then
        return ""
    end

    local letters = {}
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("GuiObject") and child.Visible then
            local lbl = child:FindFirstChild("Letter")
            if lbl and lbl:IsA("TextLabel") and lbl.Text ~= "" then
                table.insert(letters, { t = lbl.Text, p = child.AbsolutePosition.X })
            end
        end
    end

    table.sort(letters, function(a, b)
        return a.p < b.p
    end)

    local prefix = ""
    for _, letter in ipairs(letters) do
        prefix = prefix .. letter.t
    end

    return prefix:lower()
end

local function GetLivePrefix()
    local focused = UserInputService:GetFocusedTextBox()
    if focused and focused ~= searchBox then
        local raw = tostring(focused.Text or "")
        local clean = raw:lower():gsub("%s+", "")
        clean = clean:gsub("[^a-z]", "")
        if #clean > 0 then
            return clean
        end
    end
    return GetCurrentPrefix()
end

local function PushLimited(list, value, limit)
    if #list < limit then
        table.insert(list, value)
    end
end

local function CompareWords(a, b)
    if lengthPriority == "longest" then
        if #a ~= #b then
            return #a > #b
        end
    elseif lengthPriority == "shortest" then
        if #a ~= #b then
            return #a < #b
        end
    else
        local target = math.floor((minLength + maxLength) / 2)
        local da = math.abs(#a - target)
        local db = math.abs(#b - target)
        if da ~= db then
            return da < db
        end
    end

    return a < b
end

local function SortWordList(list)
    table.sort(list, CompareWords)
end

local function CustomRank(word, context)
    local tag = CustomWordTags[word] or "all"

    if customWordPriority == "trap" then
        if tag ~= "trap" then
            return 99
        end
        return 1
    elseif customWordPriority == "solve" then
        if tag ~= "solve" then
            return 99
        end
        return 1
    end

    if context == "trap" then
        if tag == "trap" then
            return 1
        elseif tag == "all" then
            return 2
        else
            return 3
        end
    else
        if tag == "solve" then
            return 1
        elseif tag == "all" then
            return 2
        else
            return 3
        end
    end
end

local function SortCustomWordList(list, context)
    table.sort(list, function(a, b)
        local ra = CustomRank(a, context)
        local rb = CustomRank(b, context)

        if ra ~= rb then
            return ra < rb
        end

        if context == "trap" then
            local da = tonumber(CustomWordDiffs[a] or 0) or 0
            local db = tonumber(CustomWordDiffs[b] or 0) or 0
            if da ~= db then
                return da > db
            end
        end

        return CompareWords(a, b)
    end)
end

local function GetPrefixCandidates(prefix)
    if #prefix >= 3 then
        return PrefixBuckets3[prefix:sub(1, 3)] or {}
    end
    if #prefix == 2 then
        return PrefixBuckets2[prefix:sub(1, 2)] or {}
    end
    if #prefix == 1 then
        return PrefixBuckets1[prefix:sub(1, 1)] or {}
    end
    return Words
end

local function GetSuffixCandidates(query)
    if #query >= 3 then
        return SuffixBuckets3[query:sub(-3)] or {}
    end
    if #query == 2 then
        return SuffixBuckets2[query:sub(-2)] or {}
    end
    if #query == 1 then
        return SuffixBuckets1[query:sub(-1)] or {}
    end
    return Words
end

local function ShouldShowCustomWord(word, context)
    local tag = CustomWordTags[word] or "all"

    if customWordPriority == "trap" then
        return tag == "trap"
    end

    if customWordPriority == "solve" then
        return tag == "solve"
    end

    if context == "trap" then
        return tag == "trap" or tag == "all"
    end

    return tag == "solve" or tag == "all"
end

local function GetSuggestions(prefix)
    local key = prefix .. "|" .. customWordPriority .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
    if SuggestionCache[key] then
        return SuggestionCache[key]
    end

    local normal = {}
    local custom = {}
    local candidates = GetPrefixCandidates(prefix)

    for _, word in ipairs(candidates) do
        if word:sub(1, #prefix) == prefix and #word >= minLength and #word <= maxLength then
            if CustomWordSet[word] then
                if ShouldShowCustomWord(word, "suggestion") then
                    table.insert(custom, word)
                end
            else
                table.insert(normal, word)
            end

            if #normal >= 10 and #custom >= 10 then
                break
            end
        end
    end

    SortWordList(normal)
    SortCustomWordList(custom, "suggestion")

    SuggestionCache[key] = {
        normal = normal,
        custom = custom,
    }

    return SuggestionCache[key]
end

local function GetSuffixCount(suffix)
    if SuffixCountCache[suffix] ~= nil then
        return SuffixCountCache[suffix]
    end

    local count = 0
    local candidates = GetPrefixCandidates(suffix)

    for _, word in ipairs(candidates) do
        if word:sub(1, #suffix) == suffix then
            count = count + 1
        end
    end

    SuffixCountCache[suffix] = count
    return count
end

local function FindTraps(prefix)
    local key = prefix .. "|" .. customWordPriority .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
    if TrapCache[key] then
        return TrapCache[key]
    end

    local normalEntries = {}
    local customDirectWords = {}
    local customDynamicEntries = {}
    local seenNormal = {}
    local seenCustomDirect = {}
    local seenCustomDynamic = {}
    local candidates = GetPrefixCandidates(prefix)

    local function suffixQualifies(suffix)
        local count = GetSuffixCount(suffix)
        return count > 0 and count <= 6
    end

    for _, word in ipairs(candidates) do
        if word:sub(1, #prefix) == prefix then
            local tag = CustomWordTags[word] or "all"
            local isCustom = CustomWordSet[word] == true

            if isCustom and tag == "trap" and ShouldShowCustomWord(word, "trap") then
                if not seenCustomDirect[word] then
                    table.insert(customDirectWords, word)
                    seenCustomDirect[word] = true
                end
            else
                local suffix3 = word:sub(-3)
                local suffix2 = word:sub(-2)

                local selectedSuffix = nil
                if #suffix3 >= 2 and (ManualTrap3[suffix3] or suffixQualifies(suffix3)) then
                    selectedSuffix = suffix3
                elseif #suffix2 >= 2 and (ManualTrap2[suffix2] or suffixQualifies(suffix2)) then
                    selectedSuffix = suffix2
                end

                if selectedSuffix then
                    if isCustom then
                        if tag == "all" and ShouldShowCustomWord(word, "trap") and not seenCustomDynamic[word] then
                            table.insert(customDynamicEntries, { word = word, suffix = selectedSuffix })
                            seenCustomDynamic[word] = true
                        end
                    else
                        if not seenNormal[word] then
                            table.insert(normalEntries, { word = word, suffix = selectedSuffix })
                            seenNormal[word] = true
                        end
                    end
                end
            end

            if #normalEntries >= 5 and #customDirectWords >= 5 and #customDynamicEntries >= 5 then
                break
            end
        end
    end

    table.sort(normalEntries, function(a, b)
        return CompareWords(a.word, b.word)
    end)

    table.sort(customDirectWords, function(a, b)
        local da = tonumber(CustomWordDiffs[a] or 0) or 0
        local db = tonumber(CustomWordDiffs[b] or 0) or 0
        if da ~= db then
            return da > db
        end
        return CompareWords(a, b)
    end)

    table.sort(customDynamicEntries, function(a, b)
        local da = tonumber(CustomWordDiffs[a.word] or 0) or 0
        local db = tonumber(CustomWordDiffs[b.word] or 0) or 0
        if da ~= db then
            return da > db
        end
        return CompareWords(a.word, b.word)
    end)

    local normal = {}
    for _, entry in ipairs(normalEntries) do
        table.insert(normal, entry.word .. " -> trap: " .. entry.suffix:upper())
    end

    local custom = {}
    for _, word in ipairs(customDirectWords) do
        local diff = tonumber(CustomWordDiffs[word] or 0) or 0
        local label = word
        if diff > 0 then
            label = label .. " " .. tostring(diff) .. "*"
        end
        table.insert(custom, label)
    end

    for _, entry in ipairs(customDynamicEntries) do
        local diff = tonumber(CustomWordDiffs[entry.word] or 0) or 0
        local label = entry.word
        if diff > 0 then
            label = label .. " " .. tostring(diff) .. "*"
        end
        table.insert(custom, label .. " -> trap: " .. entry.suffix:upper())
    end

    TrapCache[key] = {
        normal = normal,
        custom = custom,
    }

    return TrapCache[key]
end

local function SearchWords(query, mode)
    local key = mode .. "|" .. query .. "|" .. customWordPriority .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
    if SearchCache[key] then
        return SearchCache[key]
    end

    local normal = {}
    local custom = {}

    if mode == "word" then
        for _, word in ipairs(Words) do
            if word:find(query, 1, true) then
                if CustomWordSet[word] then
                    if ShouldShowCustomWord(word, "suggestion") then
                        table.insert(custom, word)
                    end
                else
                    table.insert(normal, word)
                end
                if #normal >= 25 and #custom >= 25 then
                    break
                end
            end
        end
    elseif mode == "prefix" then
        local candidates = GetPrefixCandidates(query)
        for _, word in ipairs(candidates) do
            if word:sub(1, #query) == query then
                if CustomWordSet[word] then
                    if ShouldShowCustomWord(word, "suggestion") then
                        table.insert(custom, word)
                    end
                else
                    table.insert(normal, word)
                end
                if #normal >= 25 and #custom >= 25 then
                    break
                end
            end
        end
    elseif mode == "suffix" then
        local candidates = GetSuffixCandidates(query)
        for _, word in ipairs(candidates) do
            if word:sub(-#query) == query then
                if CustomWordSet[word] then
                    if ShouldShowCustomWord(word, "suggestion") then
                        table.insert(custom, word)
                    end
                else
                    table.insert(normal, word)
                end
                if #normal >= 25 and #custom >= 25 then
                    break
                end
            end
        end
    end

    SortWordList(normal)
    SortCustomWordList(custom, "suggestion")

    SearchCache[key] = {
        normal = normal,
        custom = custom
    }

    return SearchCache[key]
end

local function BuildSection(title, items, emptyText)
    local text = title .. "\n"
    if #items > 0 then
        text = text .. table.concat(items, "\n")
    else
        text = text .. emptyText
    end
    return text
end

