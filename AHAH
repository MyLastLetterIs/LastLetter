local function ApplyPriority(list)
if #list <= 1 then
return
end

if lengthPriority == "longest" then  
	table.sort(list, function(a, b)  
		if #a ~= #b then  
			return #a > #b  
		end  
		return a < b  
	end)  
elseif lengthPriority == "shortest" then  
	table.sort(list, function(a, b)  
		if #a ~= #b then  
			return #a < #b  
		end  
		return a < b  
	end)  
else  
	local target = math.floor((minLength + maxLength) / 2)  
	table.sort(list, function(a, b)  
		local da = math.abs(#a - target)  
		local db = math.abs(#b - target)  
		if da ~= db then  
			return da < db  
		end  
		if #a ~= #b then  
			return #a < #b  
		end  
		return a < b  
	end)  
end

end

local function GetPrefixCandidates(prefix)
if #prefix >= 3 then
return PrefixBuckets3[prefix:sub(1, 3)] or {}
end
if #prefix == 2 then
return PrefixBuckets2[prefix:sub(1, 2)] or {}
end
if #prefix == 1 then
return PrefixBuckets1[prefix:sub(1, 1)] or {}
end
return Words
end

local function GetSuffixCandidates(query)
if #query >= 3 then
return SuffixBuckets3[query:sub(-3)] or {}
end
if #query == 2 then
return SuffixBuckets2[query:sub(-2)] or {}
end
if #query == 1 then
return SuffixBuckets1[query:sub(-1)] or {}
end
return Words
end

local function GetCurrentPrefix()
local inGame = playerGui:FindFirstChild("InGame")
if not inGame then
return ""
end

local frame = inGame:FindFirstChild("Frame")  
if not frame then  
	return ""  
end  

local container = frame:FindFirstChild("CurrentWord")  
if not container then  
	return ""  
end  

local letters = {}  
for _, child in ipairs(container:GetChildren()) do  
	if child:IsA("GuiObject") and child.Visible then  
		local lbl = child:FindFirstChild("Letter")  
		if lbl and lbl:IsA("TextLabel") and lbl.Text ~= "" then  
			table.insert(letters, { t = lbl.Text, p = child.AbsolutePosition.X })  
		end  
	end  
end  

table.sort(letters, function(a, b)  
	return a.p < b.p  
end)  

local prefix = ""  
for _, letter in ipairs(letters) do  
	prefix = prefix .. letter.t  
end  

return prefix:lower()

end

local function GetPageCount(normalList, customList, size)
local normalPages = math.max(1, math.ceil(#normalList / size))
local customPages = math.max(1, math.ceil(#customList / size))
return math.max(normalPages, customPages)
end

local function SlicePage(items, page, size)
local startIndex = ((page - 1) * size) + 1
local endIndex = math.min(#items, startIndex + size - 1)
local result = {}

if startIndex > #items then  
	return result  
end  

for i = startIndex, endIndex do  
	table.insert(result, items[i])  
end  

return result

end

local function GetSuggestions(prefix)
if SuggestionCache[prefix] then
return SuggestionCache[prefix]
end

local normal = {}  
local custom = {}  

for _, word in ipairs(GetPrefixCandidates(prefix)) do  
	if word:sub(1, #prefix) == prefix and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then  
		if CustomWordSet[word] then  
			table.insert(custom, word)  
		else  
			table.insert(normal, word)  
		end  
	end  
end  

ApplyPriority(normal)  
ApplyPriority(custom)  

SuggestionCache[prefix] = {  
	normal = normal,  
	custom = custom,  
}  

return SuggestionCache[prefix]

end

local function GetSuffixCount(suffix)
if SuffixCountCache[suffix] ~= nil then
return SuffixCountCache[suffix]
end

local count = 0  
for _, word in ipairs(GetPrefixCandidates(suffix)) do  
	if word:sub(1, #suffix) == suffix then  
		count += 1  
	end  
end  

SuffixCountCache[suffix] = count  
return count

end

local function FindTraps(prefix)
if TrapCache[prefix] then
return TrapCache[prefix]
end

local normal = {}  
local custom = {}  
local checkedSuffix = {}  

for _, word in ipairs(GetPrefixCandidates(prefix)) do  
	if word:sub(1, #prefix) == prefix then  
		local suffix2 = word:sub(-2)  
		local suffix3 = word:sub(-3)  

		local function handleSuffix(suffix, isManual)  
			if #suffix >= 2 and not checkedSuffix[suffix] then  
				checkedSuffix[suffix] = true  

				local isTrap = false  
				if isManual then  
					isTrap = true  
				else  
					local count = GetSuffixCount(suffix)  
					if count > 0 and count <= 6 then  
						isTrap = true  
					end  
				end  

				if isTrap then  
					local text = word .. " -> trap: " .. suffix:upper()  
					if CustomWordSet[word] then  
						table.insert(custom, text)  
					else  
						table.insert(normal, text)  
					end  
				end  
			end  
		end  

		handleSuffix(suffix3, ManualTrap3[suffix3] == true)  
		handleSuffix(suffix2, ManualTrap2[suffix2] == true)  
	end  
end  

ApplyPriority(normal)  
ApplyPriority(custom)  

TrapCache[prefix] = {  
	normal = normal,  
	custom = custom,  
}  

return TrapCache[prefix]

end

local function SearchWords(query, mode)
local key = mode .. "|" .. query .. "|" .. lengthPriority .. "|" .. tostring(minLength) .. "|" .. tostring(maxLength)
if SearchCache[key] then
return SearchCache[key]
end

local normal = {}  
local custom = {}  

if mode == "word" then  
	for _, word in ipairs(Words) do  
		if word:find(query, 1, true) and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then  
			if CustomWordSet[word] then  
				table.insert(custom, word)  
			else  
				table.insert(normal, word)  
			end  
		end  
	end  
elseif mode == "prefix" then  
	for _, word in ipairs(GetPrefixCandidates(query)) do  
		if word:sub(1, #query) == query and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then  
			if CustomWordSet[word] then  
				table.insert(custom, word)  
			else  
				table.insert(normal, word)  
			end  
		end  
	end  
elseif mode == "suffix" then  
	for _, word in ipairs(GetSuffixCandidates(query)) do  
		if word:sub(-#query) == query and #word >= minLength and (lengthPriority == "longest" or #word <= maxLength) then  
			if CustomWordSet[word] then  
				table.insert(custom, word)  
			else  
				table.insert(normal, word)  
			end  
		end  
	end  
end  

ApplyPriority(normal)  
ApplyPriority(custom)  

SearchCache[key] = {  
	normal = normal,  
	custom = custom  
}  

return SearchCache[key]

end

local function FormatThreePerLine(items)
local lines = {}
for i = 1, #items, 3 do
local line = {}
table.insert(line, items[i])
if items[i + 1] then
table.insert(line, items[i + 1])
end
if items[i + 2] then
table.insert(line, items[i + 2])
end
table.insert(lines, table.concat(line, ", "))
end
return lines
end

local function BuildSection(title, items, emptyText)
if #items > 0 then
return title .. "\n" .. table.concat(FormatThreePerLine(items), "\n")
end
return title .. "\n" .. emptyText
end

