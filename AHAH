local function AddWordToBuckets(word, isCustom)
    word = tostring(word or ""):lower():gsub("%s+", "")
    if not word:match("^[a-z]+$") then
        return false
    end
    if #word < 3 then
        return false
    end

    local inserted = false

    if not WordSet[word] then
        WordSet[word] = true
        table.insert(Words, word)
        inserted = true

        local p1 = word:sub(1, 1)
        local p2 = word:sub(1, 2)
        local p3 = word:sub(1, 3)
        local s1 = word:sub(-1)
        local s2 = word:sub(-2)
        local s3 = word:sub(-3)

        if #p1 == 1 then
            AddToBucket(PrefixBuckets1, p1, word)
        end
        if #p2 == 2 then
            AddToBucket(PrefixBuckets2, p2, word)
        end
        if #p3 == 3 then
            AddToBucket(PrefixBuckets3, p3, word)
        end
        if #s1 == 1 then
            AddToBucket(SuffixBuckets1, s1, word)
        end
        if #s2 == 2 then
            AddToBucket(SuffixBuckets2, s2, word)
        end
        if #s3 == 3 then
            AddToBucket(SuffixBuckets3, s3, word)
        end
    end

    if isCustom then
        CustomWordSet[word] = true
    end

    return inserted
end

local function FetchUrl(url)
    local ok1, body1 = pcall(function()
        return game:HttpGet(url, true)
    end)
    if ok1 and type(body1) == "string" and #body1 > 0 then
        return body1
    end

    local ok2, resp = pcall(function()
        return HttpService:RequestAsync({
            Url = url,
            Method = "GET"
        })
    end)

    if ok2 and resp and resp.Success and type(resp.Body) == "string" and #resp.Body > 0 then
        return resp.Body
    end

    return nil
end

local function LoadDictionaries()
    local loadedUnique = 0

    if isfile(WORDS_FILE) then
        local content = readfile(WORDS_FILE)
        for word in content:gmatch("%S+") do
            if AddWordToBuckets(word, false) then
                loadedUnique = loadedUnique + 1
            end
        end
        print("Loaded " .. loadedUnique .. " unique words from cache")
        print("TOTAL UNIQUE WORDS: " .. #Words)
        return
    end

    local allText = ""
    for _, url in ipairs(dictionaries) do
        local body = FetchUrl(url)
        if body and #body > 1000 then
            allText = allText .. "\n" .. body
        else
            warn("Skipped or failed: " .. url)
        end
        task.wait(0.8)
    end

    if allText ~= "" then
        writefile(WORDS_FILE, allText)
        for word in allText:gmatch("%S+") do
            if AddWordToBuckets(word, false) then
                loadedUnique = loadedUnique + 1
            end
        end
        print("Combined unique words: " .. loadedUnique)
    end

    print("TOTAL UNIQUE WORDS: " .. #Words)
end

local function LoadCustomWords()
    if not isfile(CUSTOM_WORDS_FILE) then
        return
    end

    local content = readfile(CUSTOM_WORDS_FILE)
    for word in content:gmatch("%S+") do
        AddWordToBuckets(word, true)
    end

    ClearCaches()
    print("Loaded custom words: " .. tostring(CountCustomWords()))
end

local function SaveCustomWords()
    local list = {}
    for word in pairs(CustomWordSet) do
        table.insert(list, word)
    end
    table.sort(list)
    writefile(CUSTOM_WORDS_FILE, table.concat(list, "\n"))
end

