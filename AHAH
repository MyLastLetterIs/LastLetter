local function FireKeyObject(obj)
	for _, signal in ipairs({ "MouseButton1Click", "Activated", "InputBegan" }) do
		local s = obj[signal]
		if s then
			for _, conn in ipairs(getconnections(s)) do
				pcall(function()
					conn:Fire()
				end)
			end
		end
	end
end

local function FindKeyObject(char)
	local gui = player:FindFirstChild("PlayerGui")
	local overbar = gui and gui:FindFirstChild("Overbar")
	local frame = overbar and overbar:FindFirstChild("Frame")
	local keyboard = frame and frame:FindFirstChild("Keyboard")
	if not keyboard then
		return nil
	end

	char = char:upper()
	for _, rowName in ipairs({ "1", "2", "3" }) do
		local row = keyboard:FindFirstChild(rowName)
		if row then
			for _, keyObj in ipairs(row:GetChildren()) do
				if keyObj.Name:upper() == char then
					return keyObj
				end
			end
		end
	end
	return nil
end

