local function BuildAutoPlayPool(prefix)
	local pool = {}
	local searchQuery = searchBox.Text:gsub("^%s+", ""):gsub("%s+$", ""):lower()

	if searchQuery ~= "" then
		local data = SearchWords(searchQuery, searchMode)
		for _, word in ipairs(data.normal) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
		for _, word in ipairs(data.custom) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
	end

	if #pool == 0 and suggesterEnabled then
		local data = GetSuggestions(prefix)
		for _, word in ipairs(data.normal) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
		for _, word in ipairs(data.custom) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
	end

	if #pool == 0 then
		local data = GetSuggestions(prefix)
		for _, word in ipairs(data.normal) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
		for _, word in ipairs(data.custom) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
	end

	if #pool == 0 then
		for _, word in ipairs(GetCustomFallback(prefix)) do
			if not IsBlacklisted(word) and not UsedWords[word] then
				pool[#pool + 1] = word
			end
		end
	end

	return pool
end

local function PickAutoPlayWord(prefix)
	local pool = BuildAutoPlayPool(prefix)
	return pool[1]
end

local function verifyWord(targetWord, currentDetected, verifyStart)
	local accepted = false
	while (tick() - verifyStart) < 1.5 do
		local currentCheck = GetCurrentGameWord()
		if currentCheck == "" then
			accepted = true
			break
		end
		if currentCheck ~= targetWord and currentCheck ~= currentDetected then
			blacklistAndRemoveFromCaches(targetWord)
			blacklistAndRemoveFromCaches(currentCheck)
			accepted = true
			break
		end
		task.wait(0.05)
	end
	return accepted
end

local function handleRejectedWord(targetWord)
	blacklistAndRemoveFromCaches(targetWord)
	rejectReactionDelay()

	local current = GetCurrentGameWord()
	if current ~= "" then
		PressBackspaceTimes(#current)
	else
		PressBackspaceTimes(#targetWord)
	end

	rejectReactionDelay()
	lastDetected = "---"
	isTyping = false
	typingLock = false
	lastAutoChosen = ""
end

local function handleAcceptedWord(targetWord)
	local current = GetCurrentGameWord()
	if #current > 0 then
		PressBackspaceTimes(#current)
	end
	reactionDelay()
	PressEnter()
	UsedWords[targetWord] = true
	isMyTurnLogDetected = false
	task.wait(0.2)
	typingLock = false
	lastAutoChosen = ""
end

local function TypeWordAutoPlay(word)
	if not AutoPlayEnabled or typingLock or not IsAutoPlayTurn() then
		return
	end

	task.spawn(function()
		typingLock = true
		isTyping = true

		local ok, err = pcall(function()
			reactionDelay()

			local fullWord = tostring(word or ""):lower()
			if #fullWord == 0 then
				typingLock = false
				isTyping = false
				return
			end

			local prefix = tostring(GetCurrentPrefix() or ""):lower()
			local startIndex = 1
			if prefix ~= "" then
				local maxLen = math.min(#prefix, #fullWord)
				for i = 1, maxLen do
					if prefix:sub(i, i) ~= fullWord:sub(i, i) then
						break
					end
					startIndex = i + 1
				end
			end

			local remaining = fullWord:sub(startIndex)
			if #remaining == 0 then
				reactionDelay()
				PressEnter()
				typingLock = false
				isTyping = false
				return
			end

			local function GetHumanDelay(i, total)
				local base = math.random() * (maxDelay - minDelay) + minDelay
				local delay = base
				if minDelay >= 0.05 and maxDelay <= 0.09 then
					delay = delay + (math.random() - 0.5) * 0.015
				else
					if i / total < 0.2 then
						delay = delay + 0.04
					elseif i / total > 0.8 then
						delay = delay + 0.03
					end
					delay = delay + (math.random() - 0.5) * 0.03
				end
				if math.random() < 0.08 then
					delay = delay + math.random(12, 28) / 100
				end
				if math.random() < 0.15 then
					delay = delay + math.random(5, 10) / 100
				end
				return math.clamp(delay, minDelay, maxDelay + 0.3)
			end

			for i = 1, #remaining do
				local char = remaining:sub(i, i)
				if char:match("%a") then
					local keyObj = FindKeyObject(char)
					if keyObj then
						FireKeyObject(keyObj)
					end
				end
				task.wait(GetHumanDelay(i, #remaining))
			end

			task.wait(GetHumanDelay(#remaining, #remaining) + math.random(5, 15) / 100)
			PressEnter()

			local verifyStart = tick()
			local accepted = verifyWord(fullWord, prefix, verifyStart)
			if not accepted then
				handleRejectedWord(fullWord)
			else
				handleAcceptedWord(fullWord)
			end
		end)

		if not ok then
			warn(err)
		end

		typingLock = false
		isTyping = false
	end)
end

local function TypeWordFromButton(word)
	if typingLock then
		return
	end

	task.spawn(function()
		typingLock = true

		local fullWord = tostring(word or ""):lower()
		if #fullWord == 0 then
			typingLock = false
			return
		end

		local prefix = tostring(GetCurrentPrefix() or ""):lower()
		local startIndex = 1
		if prefix ~= "" then
			local maxLen = math.min(#prefix, #fullWord)
			for i = 1, maxLen do
				if prefix:sub(i, i) ~= fullWord:sub(i, i) then
					break
				end
				startIndex = i + 1
			end
		end

		local remaining = fullWord:sub(startIndex)
		local function GetButtonDelay()
			return math.random() * (maxDelay - minDelay) + minDelay
		end

		for i = 1, #remaining do
			local char = remaining:sub(i, i)
			if char:match("%a") then
				local keyObj = FindKeyObject(char)
				if keyObj then
					FireKeyObject(keyObj)
				end
			end
			if i < #remaining then
				task.wait(GetButtonDelay())
			end
		end

		task.wait(GetButtonDelay())
		PressEnter()
		typingLock = false
	end)
end

