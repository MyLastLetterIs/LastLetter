local function RenderSearch(query)
    local data = SearchWords(query, searchMode)
    local text = "Search (" .. searchMode:upper() .. "): " .. query .. "\n\n"

    if #data.custom > 0 then
        text = text .. BuildSection("Custom Words:", data.custom, "") .. "\n\n"
    end

    text = text .. BuildSection("Results:", data.normal, "No matches")
    return text
end

local function RenderPrefix(prefix)
    local text = "Prefix: " .. prefix:upper() .. "\n\n"

    if suggesterEnabled then
        local data = GetSuggestions(prefix)
        if #data.custom > 0 then
            text = text .. BuildSection("Custom Words:", data.custom, "") .. "\n\n"
        end
        text = text .. BuildSection("Suggestions:", data.normal, "No matches") .. "\n\n"
    end

    if trapModeEnabled then
        local data = FindTraps(prefix)
        if #data.custom > 0 then
            text = text .. BuildSection("Custom Words:", data.custom, "") .. "\n\n"
        end
        text = text .. BuildSection("Traps:", data.normal, "No traps")
    end

    if not suggesterEnabled and not trapModeEnabled then
        text = text .. "Turn Suggester or Trap Mode ON"
    end

    return text
end

local lastPrefix = ""
local lastSearch = ""
local lastSearchMode = ""
local lastPriority = ""
local lastSuggesterState = false
local lastTrapState = false
local lastRenderedText = ""
local lastUpdate = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastUpdate < 0.12 then
        return
    end
    lastUpdate = now

    local query = searchBox.Text:gsub("^%s+", ""):gsub("%s+$", ""):lower()
    local needsSearch = query ~= ""

    if needsSearch then
        if query == lastSearch and searchMode == lastSearchMode and lengthPriority == lastPriority and not uiDirty then
            return
        end

        local text = RenderSearch(query)
        if text ~= lastRenderedText then
            suggestionLabel.Text = text
            lastRenderedText = text
        end

        lastSearch = query
        lastSearchMode = searchMode
        lastPriority = lengthPriority
        uiDirty = false
        return
    end

    local prefix = GetCurrentPrefix()
    if prefix == "" then
        local text = "Turn Suggester or Trap Mode ON"
        if suggestionLabel.Text ~= text then
            suggestionLabel.Text = text
            lastRenderedText = text
        end
        uiDirty = false
        lastPrefix = ""
        return
    end

    if prefix == lastPrefix and not uiDirty and searchMode == lastSearchMode and lengthPriority == lastPriority and suggesterEnabled == lastSuggesterState and trapModeEnabled == lastTrapState then
        return
    end

    local text = RenderPrefix(prefix)
    if text ~= lastRenderedText then
        suggestionLabel.Text = text
        lastRenderedText = text
    end

    lastPrefix = prefix
    lastSearch = ""
    lastSearchMode = searchMode
    lastPriority = lengthPriority
    lastSuggesterState = suggesterEnabled
    lastTrapState = trapModeEnabled
    uiDirty = false
end)

