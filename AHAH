local function ApplyPriority(list)
	if #list <= 1 then
		return
	end
	if lengthPriority == "longest" then
		table.sort(list, function(a, b)
			return #a == #b and a < b or #a > #b
		end)
	elseif lengthPriority == "shortest" then
		table.sort(list, function(a, b)
			return #a == #b and a < b or #a < #b
		end)
	else
		local target = math.floor((minLength + maxLength) / 2)
		table.sort(list, function(a, b)
			local da, db = math.abs(#a - target), math.abs(#b - target)
			if da ~= db then
				return da < db
			end
			if #a ~= #b then
				return #a < #b
			end
			return a < b
		end)
	end
end

local function GetPrefixCandidates(prefix)
	if #prefix >= 3 then return PrefixBuckets3[prefix:sub(1, 3)] or {} end
	if #prefix == 2 then return PrefixBuckets2[prefix:sub(1, 2)] or {} end
	if #prefix == 1 then return PrefixBuckets1[prefix:sub(1, 1)] or {} end
	return Words
end

local function GetSuffixCandidates(query)
	if #query >= 3 then return SuffixBuckets3[query:sub(-3)] or {} end
	if #query == 2 then return SuffixBuckets2[query:sub(-2)] or {} end
	if #query == 1 then return SuffixBuckets1[query:sub(-1)] or {} end
	return Words
end

local function GetCurrentPrefix()
	local inGame = playerGui:FindFirstChild("InGame")
	local frame = inGame and inGame:FindFirstChild("Frame")
	local container = frame and frame:FindFirstChild("CurrentWord")
	if not container then return "" end
	local letters = {}
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("GuiObject") and child.Visible then
			local lbl = child:FindFirstChild("Letter")
			if lbl and lbl:IsA("TextLabel") and lbl.Text ~= "" then
				letters[#letters + 1] = { t = lbl.Text, p = child.AbsolutePosition.X }
			end
		end
	end
	table.sort(letters, function(a, b) return a.p < b.p end)
	local prefix = ""
	for _, letter in ipairs(letters) do
		prefix ..= letter.t
	end
	return prefix:lower()
end

