local function GetCurrentPrefix()
    local inGame = playerGui:FindFirstChild("InGame")
    if not inGame then
        return ""
    end

    local frame = inGame:FindFirstChild("Frame")
    if not frame then
        return ""
    end

    local container = frame:FindFirstChild("CurrentWord")
    if not container then
        return ""
    end

    local letters = {}
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("GuiObject") and child.Visible then
            local lbl = child:FindFirstChild("Letter")
            if lbl and lbl:IsA("TextLabel") and lbl.Text ~= "" then
                table.insert(letters, { t = lbl.Text, p = child.AbsolutePosition.X })
            end
        end
    end

    table.sort(letters, function(a, b)
        return a.p < b.p
    end)

    local prefix = ""
    for _, letter in ipairs(letters) do
        prefix = prefix .. letter.t
    end

    return prefix:lower()
end

local function GetCandidates(prefix)
    if prefix == "" then
        return Words
    end

    if #prefix >= 2 then
        return PrefixBuckets2[prefix:sub(1, 2)] or {}
    end

    return PrefixBuckets1[prefix:sub(1, 1)] or {}
end

local function PushLimited(list, value, limit)
    if #list < limit then
        table.insert(list, value)
    end
end

local function GetSuggestions(prefix)
    if SuggestionCache[prefix] then
        return SuggestionCache[prefix]
    end

    local normal = {}
    local custom = {}
    local candidates = GetCandidates(prefix)

    for _, word in ipairs(candidates) do
        if word:sub(1, #prefix) == prefix and #word >= minLength and #word <= maxLength then
            if CustomWordSet[word] then
                PushLimited(custom, word, 10)
            else
                PushLimited(normal, word, 10)
            end

            if #normal >= 10 and #custom >= 10 then
                break
            end
        end
    end

    SuggestionCache[prefix] = {
        normal = normal,
        custom = custom,
    }

    return SuggestionCache[prefix]
end

local function GetSuffixCount(suffix)
    if SuffixCountCache[suffix] ~= nil then
        return SuffixCountCache[suffix]
    end

    local count = 0
    local candidates = GetCandidates(suffix)

    for i = 1, math.min(#candidates, 25) do
        local w = candidates[i]
        if w:sub(1, #suffix) == suffix then
            count = count + 1
        end
        if count > 6 then
            break
        end
    end

    SuffixCountCache[suffix] = count
    return count
end

local function FindTraps(prefix)
    if TrapCache[prefix] then
        return TrapCache[prefix]
    end

    local normal = {}
    local custom = {}
    local checkedSuffix = {}
    local candidates = GetCandidates(prefix)

    for _, word in ipairs(candidates) do
        if word:sub(1, #prefix) == prefix then
            local suffix2 = word:sub(-2)
            local suffix3 = word:sub(-3)

            local function handleSuffix(suffix, isManual)
                if #suffix >= 2 and not checkedSuffix[suffix] then
                    checkedSuffix[suffix] = true

                    local isTrap = false
                    if isManual then
                        isTrap = true
                    else
                        local count = GetSuffixCount(suffix)
                        if count > 0 and count <= 6 then
                            isTrap = true
                        end
                    end

                    if isTrap then
                        local text = word .. " -> trap: " .. suffix:upper()
                        if CustomWordSet[word] then
                            PushLimited(custom, text, 5)
                        else
                            PushLimited(normal, text, 5)
                        end
                    end
                end
            end

            handleSuffix(suffix3, ManualTrap3[suffix3] == true)
            handleSuffix(suffix2, ManualTrap2[suffix2] == true)

            if #normal >= 5 and #custom >= 5 then
                break
            end
        end
    end

    TrapCache[prefix] = {
        normal = normal,
        custom = custom,
    }

    return TrapCache[prefix]
end

local function BuildSection(title, items, emptyText)
    local text = title .. "\n"
    if #items > 0 then
        text = text .. table.concat(items, "\n")
    else
        text = text .. emptyText
    end
    return text
end

local function RefreshSuggestionText(prefix)
    local blocks = {}
    table.insert(blocks, "Prefix: " .. prefix:upper())

    local suggestionData = GetSuggestions(prefix)

    if suggesterEnabled then
        if #suggestionData.custom > 0 then
            table.insert(blocks, BuildSection("Custom Words:", suggestionData.custom, ""))
        end
        table.insert(blocks, BuildSection("Suggestions:", suggestionData.normal, "No matches"))
    end

    if trapModeEnabled then
        local trapData = FindTraps(prefix)

        if #trapData.custom > 0 then
            table.insert(blocks, BuildSection("Custom Words:", trapData.custom, ""))
        end
        table.insert(blocks, BuildSection("TRAPS:", trapData.normal, "No strong traps found"))
    end

    return table.concat(blocks, "\n\n")
end

local lastPrefix = ""
local lastCheckTime = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastCheckTime < 0.08 then
        return
    end
    lastCheckTime = now

    local prefix = GetCurrentPrefix()
    if prefix == "" or prefix == lastPrefix then
        return
    end
    lastPrefix = prefix

    local text = RefreshSuggestionText(prefix)
    if suggestionLabel.Text ~= text then
        suggestionLabel.Text = text
    end
end)
